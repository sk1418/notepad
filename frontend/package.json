{
  "name": "notepad-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:be": "cd .. && SESSION_SIGN_KEY=${SESSION_SIGN_KEY:-$(node -e 'console.log(require(\"crypto\").randomBytes(32).toString(\"hex\"))')} ./gradlew --console=plain run",
    "start": "concurrently -k -n BE,FE -c blue,green \"npm:dev:be\" \"npm:dev\"",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@types/http-proxy": "^1.17.17",
    "concurrently": "^10.0.3",
    "http-proxy": "^1.18.1",
    "typescript": "^5.6.0",
    "vite": "^7.0.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "marked": "^18.0.7",
    "marked-highlight": "^2.2.4"
  }
}
